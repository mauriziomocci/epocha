# Django
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True

# Database
DATABASE_URL=postgres://epocha:epocha@db:5432/epocha

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# LLM Provider Configuration
# Epocha uses the OpenAI SDK with configurable base_url.
# All providers below are compatible without code changes.
EPOCHA_LLM_PROVIDER=openai

# === OPTION A: LM Studio (local, free, offline, no limits) ===
# Download from https://lmstudio.ai, load a model, start the server.
# EPOCHA_LLM_API_KEY=lm-studio
# EPOCHA_LLM_MODEL=qwen3-8b
# EPOCHA_LLM_BASE_URL=http://localhost:1234/v1

# === OPTION B: Google Gemini (cloud, free tier: 1000 req/day) ===
# Get your API key from https://aistudio.google.com/apikey
EPOCHA_LLM_API_KEY=your-api-key-here
EPOCHA_LLM_MODEL=gemini-2.5-flash-lite
EPOCHA_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# === Other providers ===
# Groq:        BASE_URL=https://api.groq.com/openai/v1         MODEL=llama-3.1-8b-instant
# OpenRouter:  BASE_URL=https://openrouter.ai/api/v1           MODEL=free-model-name
# Ollama:      BASE_URL=http://localhost:11434/v1               MODEL=qwen2.5:7b
# OpenAI:      BASE_URL=                                       MODEL=gpt-4o-mini
# Together AI: BASE_URL=https://api.together.xyz/v1            MODEL=model-name
# Mistral:     BASE_URL=https://api.mistral.ai/v1              MODEL=mistral-small-latest

# === Chat-specific provider (optional, smarter model for conversations) ===
# Leave empty to use the same provider as above for everything.
# EPOCHA_CHAT_LLM_API_KEY=your-gemini-api-key
# EPOCHA_CHAT_LLM_MODEL=gemini-2.5-flash-lite
# EPOCHA_CHAT_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

EPOCHA_MAX_AGENTS=50
EPOCHA_TICK_INTERVAL=5
