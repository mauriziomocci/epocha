# Django
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True

# Database
DATABASE_URL=postgres://epocha:epocha@db:5432/epocha

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# LLM (using Google Gemini via OpenAI-compatible API — free tier)
# Get your API key from https://aistudio.google.com/apikey
EPOCHA_LLM_PROVIDER=openai
EPOCHA_LLM_API_KEY=your-api-key-here
EPOCHA_LLM_MODEL=gemini-2.5-flash-lite
EPOCHA_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Alternative providers (change BASE_URL and MODEL):
# OpenAI:     EPOCHA_LLM_BASE_URL=  (leave empty)  MODEL=gpt-4o-mini
# Groq:       EPOCHA_LLM_BASE_URL=https://api.groq.com/openai/v1  MODEL=llama-3.1-8b-instant
# OpenRouter:  EPOCHA_LLM_BASE_URL=https://openrouter.ai/api/v1  MODEL=free-model-name
# Together AI: EPOCHA_LLM_BASE_URL=https://api.together.xyz/v1  MODEL=model-name
# Mistral:     EPOCHA_LLM_BASE_URL=https://api.mistral.ai/v1  MODEL=mistral-small-latest

EPOCHA_MAX_AGENTS=50
EPOCHA_TICK_INTERVAL=5
