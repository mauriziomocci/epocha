# Django
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=generate-a-strong-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-domain.com

# Database
DATABASE_URL=postgres://epocha:strong-password@db:5432/epocha

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

# CORS
CORS_ALLOWED_ORIGINS=https://your-domain.com

# LLM
EPOCHA_LLM_PROVIDER=openai
EPOCHA_LLM_API_KEY=your-api-key-here
EPOCHA_LLM_MODEL=gemini-2.5-flash-lite
EPOCHA_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
EPOCHA_MAX_AGENTS=50
EPOCHA_TICK_INTERVAL=5
